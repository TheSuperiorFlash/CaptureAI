{
  "name": "captureai-api",
  "version": "1.0.0",
  "description": "Cloudflare Workers API for CaptureAI with AI Gateway integration",
  "main": "src/index.js",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "tail": "wrangler tail",
    "db:init": "wrangler d1 execute captureai-db --file=./schema.sql",
    "db:migrate": "wrangler d1 migrations apply captureai-db",
    "test": "jest --config jest.config.js",
    "test:watch": "jest --config jest.config.js --watch",
    "test:coverage": "jest --config jest.config.js --coverage",
    "test:verbose": "jest --config jest.config.js --verbose"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "ai-gateway",
    "openai"
  ],
  "author": "Grayson Kramer",
  "license": "ISC",
  "devDependencies": {
    "@babel/core": "^7.28.5",
    "@babel/preset-env": "^7.28.5",
    "@jest/globals": "^30.2.0",
    "babel-jest": "^30.2.0",
    "jest": "^30.2.0",
    "wrangler": "^4.69.0"
  }
}
